-- Задание 1:
-- Таблица examination содержит поля id (идентификатор абитуриента) и scores (баллы от 0 до 100).
-- Требуется добавить колонку с позицией абитуриента в общем рейтинге (по убыванию баллов).

-- Используем оконную функцию RANK(), которая назначает одинаковый ранг при равных баллах,
-- а затем пропускает следующие ранги (как в спортивном рейтинге).
-- Если нужен рейтинг без пропусков (например, 1,2,2,3), можно использовать DENSE_RANK().

SELECT 
    id, 
    scores, 
    RANK() OVER (ORDER BY scores DESC) AS position
FROM 
    examination
ORDER BY 
    position;