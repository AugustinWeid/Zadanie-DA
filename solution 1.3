"""
На пустынном шоссе вероятность появления автомобиля за 30-минутный период составляет 0.95.
Какова вероятность его появления за 10 минут? А за 27 минут?
Ответ дать в процентах, округлив до десятых через точку с запятой, например: 42,7; 95,0.
"""

import math

def probability(p30, t30, t_target):
    """
    Вычисляет вероятность появления хотя бы одного автомобиля за время t_target,
    исходя из вероятности p30 за время t30, предполагая пуассоновский процесс
    (постоянная интенсивность).
    """
    # Сначала находим интенсивность λ из уравнения: 1 - exp(-λ * t30) = p30
    # exp(-λ * t30) = 1 - p30
    # -λ * t30 = ln(1 - p30)
    # λ = -ln(1 - p30) / t30
    lambda_ = -math.log(1 - p30) / t30
    # Вероятность за время t_target:
    p_target = 1 - math.exp(-lambda_ * t_target)
    return p_target

if __name__ == "__main__":
    p30 = 0.95   # вероятность за 30 мин
    t30 = 30
    t10 = 10
    t27 = 27

    p10 = probability(p30, t30, t10)
    p27 = probability(p30, t30, t27)

    # Перевод в проценты и округление до десятых
    p10_percent = round(p10 * 100, 1)
    p27_percent = round(p27 * 100, 1)

    # Замена точки на запятую для десятичного разделителя
    p10_str = str(p10_percent).replace('.', ',')
    p27_str = str(p27_percent).replace('.', ',')

    # Форматирование итогового ответа
    result10 = f"{p10_str}"
    result27 = f"{p27_str}"
    print(f"Вероятность за 10 минут: {result10}")
    print(f"Вероятность за 27 минут: {result27}")